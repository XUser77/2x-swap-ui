// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PointSource {
  TRADING
  LIQUIDITY
  REFERRAL
  CONTRIBUTOR
}

enum ScoreStatus {
  PENDING
  FINAL
}

model User {
  id           String @id @default(uuid())
  wallet       String @unique
  referralCode String @unique

  nonce String?

  referredById String?
  referredBy   User?   @relation("UserReferral", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferral")

  createdAt DateTime @default(now())

  // Relations
  trades             TradeScore[]
  liquiditySnapshots LiquiditySnapshot[]
  referralEarnings   ReferralEarning[]   @relation("Referrer")
  referredActivity   ReferralEarning[]   @relation("Invitee")
  seasonTotals       SeasonTotal[]

  @@index([wallet])
}

model Season {
  id         Int      @id @default(autoincrement())
  name       String
  startAt    DateTime
  endAt      DateTime
  multiplier Float
  isActive   Boolean  @default(false)

  tradeScores    TradeScore[]
  liquiditySnaps LiquiditySnapshot[]
  seasonTotals   SeasonTotal[]
  referralEvents ReferralEarning[]

  @@index([isActive])
}

model TradeScore {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  txHash     String
  volume     Decimal
  baseScore  Float
  multiplier Float
  finalScore Float

  lpHurt Boolean

  createdAt DateTime @default(now())

  @@index([userId, seasonId])
  @@index([txHash])
}

model LiquiditySnapshot {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  avgDailyBalance   Decimal
  loyaltyMultiplier Float
  baseScore         Float
  finalScore        Float

  snapshotDate DateTime

  @@index([userId, snapshotDate])
}

model ReferralEarning {
  id String @id @default(uuid())

  referrerId String
  referrer   User   @relation("Referrer", fields: [referrerId], references: [id])

  inviteeId String
  invitee   User   @relation("Invitee", fields: [inviteeId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  inviteeActivityPoints Float
  referralPoints        Float
  capped                Boolean

  createdAt DateTime @default(now())

  @@unique([referrerId, inviteeId, seasonId])
}

model SeasonTotal {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  traderActivityPoints Float @default(0)
  lpActivityPoints     Float @default(0)
  referralPoints       Float @default(0)
  contributorPoints    Float @default(0)

  totalPoints Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, seasonId])
}

model UserLPState {
  userId String @id
  pool   String

  lastBalance Decimal
  lastUpdated DateTime

  currentStreak Int // loyalty days
}

model WaitlistMail {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}
